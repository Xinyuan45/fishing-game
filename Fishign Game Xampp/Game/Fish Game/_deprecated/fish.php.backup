<?php
session_start();
require 'db.php';

if (!isset($_SESSION['user'])) {
    header("Location: login.php");
    exit;
}

$user = $_SESSION['user'];
$mapId = $_GET['map_id'] ?? 1;

// Get map info
$mapStmt = $pdo->prepare("SELECT * FROM maps WHERE id = ?");
$mapStmt->execute([$mapId]);
$map = $mapStmt->fetch();

if (!$map) {
    header("Location: maps.php");
    exit;
}

// Get user's bait inventory
$baitStmt = $pdo->prepare("SELECT b.*, ub.quantity FROM baits b 
    LEFT JOIN user_baits ub ON b.id = ub.bait_id AND ub.user_id = ? 
    WHERE ub.quantity > 0 OR b.id = 1 
    ORDER BY b.price ASC");
$baitStmt->execute([$user['id']]);
$availableBaits = $baitStmt->fetchAll(PDO::FETCH_ASSOC);

// Check if user has any bait
$hasBait = false;
foreach ($availableBaits as $bait) {
    if (($bait['quantity'] ?? 0) > 0) {
        $hasBait = true;
        break;
    }
}
?>
<!DOCTYPE html>
<html>
<head>
    <title>Fishing - <?= htmlspecialchars($map['name']) ?></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="style.css">
    <style>
        .minigame-container {
            display: none;
            position: relative;
            width: 100%;
            height: 60px;
            background: rgba(15, 23, 42, 0.8);
            border: 2px solid var(--primary);
            border-radius: 8px;
            overflow: hidden;
            margin: 20px 0;
        }
        
        .minigame-bar {
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            width: 4px;
            background: var(--primary);
            transition: left 0.05s linear;
        }
        
        .minigame-target {
            position: absolute;
            top: 0;
            height: 100%;
            background: rgba(34, 197, 94, 0.3);
            border: 2px solid #22c55e;
        }
        
        .minigame-instructions {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            font-weight: bold;
            z-index: 10;
            pointer-events: none;
        }
    </style>
</head>
<body>

<?php include 'navbar.php'; ?>

<div class="container mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="glass-card p-5">
                <div class="mb-3">
                    <span class="badge bg-info">📍 <?= htmlspecialchars($map['name']) ?></span>
                </div>

                <div id="minigame" class="minigame-container">
                    <div class="minigame-instructions">Press SPACE when the bar is in the green zone!</div>
                    <div class="minigame-target"></div>
                    <div class="minigame-bar"></div>
                </div>

                <div id="result" class="mb-4"></div>

                <button id="fishButton" class="btn btn-primary btn-lg px-5 py-3 rounded-pill shadow-lg" <?= !$hasBait ? 'disabled title="You need bait to fish!"' : '' ?>>
                    🌊 Cast Line
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
$(document).ready(function () {
    let minigameActive = false;
    let barPosition = 0;
    let barDirection = 1;
    let barSpeed = 2;
    let targetStart = 40;
    let targetWidth = 20;
    let animationFrame;

    $("#fishButton").click(function () {
        let btn = $(this);
        let baitId = $("#baitSelect").val();
        btn.prop("disabled", true);
        $("#result").html("");
        $("#fishing-animation").show();

        // Hook the fish
        $.ajax({
            url: "hook_fish.php?map_id=<?= $mapId ?>&bait_id=" + baitId,
            dataType: 'json',
            success: function (data) {
                $("#fishing-animation").hide();
                
                if (data.error) {
                    $("#result").html(`<div class="alert alert-danger">${data.error}</div>`);
                    btn.prop("disabled", false);
                    return;
                }

                // Start minigame
                startMinigame(data.difficulty);
            },
            error: function () {
                $("#fishing-animation").hide();
                $("#result").html("<div class='alert alert-danger'>⚠️ Connection failed</div>");
                btn.prop("disabled", false);
            }
        });
    });

    function startMinigame(difficulty) {
        // Adjust difficulty
        barSpeed = 1 + (difficulty * 0.8);
        targetWidth = Math.max(10, 30 - (difficulty * 5));
        targetStart = Math.random() * (100 - targetWidth);

        $(".minigame-target").css({
            left: targetStart + "%",
            width: targetWidth + "%"
        });

        barPosition = 0;
        barDirection = 1;
        minigameActive = true;

        $("#minigame").show();
        $("#result").html("<p class='text-warning'>🎯 Hit the green zone!</p>");

        animateBar();
    }

    function animateBar() {
        if (!minigameActive) return;

        barPosition += barSpeed * barDirection;

        if (barPosition >= 100) {
            barPosition = 100;
            barDirection = -1;
        } else if (barPosition <= 0) {
            barPosition = 0;
            barDirection = 1;
        }

        $(".minigame-bar").css("left", barPosition + "%");

        animationFrame = requestAnimationFrame(animateBar);
    }

    $(document).keydown(function (e) {
        if (e.key === " " && minigameActive) {
            e.preventDefault();
            checkMinigame();
        }
    });

    function checkMinigame() {
        minigameActive = false;
        cancelAnimationFrame(animationFrame);
        $("#minigame").hide();

        let success = barPosition >= targetStart && barPosition <= (targetStart + targetWidth);

        $.ajax({
            url: "catch_fish.php",
            method: "POST",
            dataType: 'json',
            data: { success: success },
            success: function (data) {
                $("#result").html(`<div class="alert alert-${data.success ? 'success' : 'warning'}">${data.message}</div>`);
                $("#fishButton").prop("disabled", false);
                
                // Update level badge if leveled up
                if (data.newLevel) {
                    $(".badge.bg-primary").text("Lv " + data.newLevel);
                }
                
                // Update bait quantity in dropdown
                const selectedBait = $("#baitSelect option:selected");
                const currentQty = parseInt(selectedBait.text().match(/\((\d+) owned/)[1]);
                const newQty = Math.max(0, currentQty - 1);
                const baitName = selectedBait.text().split('(')[0].trim();
                const luckBonus = selectedBait.data('rarity');
                selectedBait.text(`${baitName} (${newQty} owned, Rarity: x${luckBonus})`);
                
                // If quantity is 0 and not worm, disable or remove option
                if (newQty === 0 && selectedBait.val() != '1') {
                    // Switch to worm if available
                    $("#baitSelect").val('1');
                }
            },
            error: function () {
                $("#result").html("<div class='alert alert-danger'>⚠️ Failed to process catch</div>");
                $("#fishButton").prop("disabled", false);
            }
        });
    }
});
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
